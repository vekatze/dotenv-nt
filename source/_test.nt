import {
  core::environment {get-env},
  this::dotenv {find-and-load-env-file},
}

define try-dotenv() -> ?unit {
  try _ = find-and-load-env-file(".env");
  try value = get-env("BUZ");
  pin value = value;
  print("result: ");
  print-line(value);
  Right(Unit)
}

define zen() -> unit {
  let _ = try-dotenv();
  Unit
}

define main() -> unit {
  zen()
}

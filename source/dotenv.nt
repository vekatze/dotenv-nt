import {
  core::environment.unsafe {set-env},
  core::file.access-mode {Read},
  core::file.descriptor {close, open},
  core::list {reverse},
  core::path {drop-last},
  core::path.entity.dirent {Dirent, dirent},
  core::path.entity.dtype {DT_REG, dtype},
  core::path.io {get-current-directory, read-directory},
  core::string {
    drop-while,
    is-empty,
    pack,
    take-while-N,
    uncons,
  },
  core::string.io {read},
  core::string.parse {parse-string},
  core::system {system, system-error},
}

define _has-rune-at-head(t: &string, ch: rune) -> bool {
  match core::string.get-first-rune(t) {
  | Right(head-rune) =>
    eq-rune(head-rune, ch)
  | Left(_) =>
    False
  }
}

define _skip-spaces(t: string) -> string {
  let t =
    drop-while(t, (ch) => {
      or::(eq-rune(ch, ` `), eq-rune(ch, `\n`))
    });
  let found-sharp on t = _has-rune-at-head(t, `#`);
  if found-sharp {
    let t =
      drop-while(core::string.drop(t, 1), (ch) => {
        ne-rune(ch, `\n`)
      });
    _skip-spaces(core::string.drop(t, 1))
  } else {
    t
  }
}

define _has-quote-at-head(t: &string) -> bool {
  _has-rune-at-head(t, `"`)
}

define _take-while-rune(t: &string, ch: rune) -> string {
  take-while-N(t, (r) => {
    ne-rune(r, ch)
  })
}

inline _read-string-while-rune(haystack: string, needle: rune) -> pair(string, string) {
  let fragment on haystack = _take-while-rune(haystack, needle);
  let fragment-length on fragment = core::string.length(fragment);
  let rest = core::string.drop(haystack, add-int(fragment-length, 1));
  Pair(fragment, rest)
}

data error {
| Parse-Error(core::string.parse.error)
| System-Error(system-error)
}

define _read-quoted-value-loop(
  rest: string,
  escaping: bool,
  acc: list(rune),
) -> either(error, pair(string, string)) {
  match uncons(rest) {
  | Left(_) =>
    Left(Parse-Error(core::string.parse.Parse-Error(*"Unexpected end of quoted value")))
  | Right(Pair(ch, rest)) =>
    if and::(eq-rune(ch, `"`), not(escaping)) {
      pin acc = reverse(acc);
      pin quoted-value = pack(acc);
      match parse-string(quoted-value) {
      | Right(value) =>
        Right(Pair(value, rest))
      | Left(e) =>
        Left(Parse-Error(e))
      }
    } else {
      let escaping = and::(eq-rune(ch, `\\`), not(escaping));
      _read-quoted-value-loop(rest, escaping, Cons(ch, acc))
    }
  }
}

define _read-quoted-value(value-rest: string) -> either(error, pair(string, string)) {
  _read-quoted-value-loop(core::string.drop(value-rest, 1), False, Nil)
}

define _read-env(env-string: string) -> either(error, unit) {
  let env-string = _skip-spaces(env-string);
  let should-finish on env-string = is-empty(env-string);
  if should-finish {
    Right(Unit)
  } else {
    let Pair(key, value-rest) = _read-string-while-rune(env-string, `=`);
    let quoted on value-rest = _has-quote-at-head(value-rest);
    if quoted {
      try Pair(value, rest) = _read-quoted-value(value-rest);
      pin value = value;
      pin key = key;
      let _ = set-env(key, value, True);
      _read-env(rest)
    } else {
      let Pair(value, rest) = _read-string-while-rune(value-rest, `\n`);
      pin value = value;
      pin key = key;
      match set-env(key, value, True) {
      | Right(_) =>
        _read-env(rest)
      | Left(e) =>
        Left(System-Error(e))
      }
    }
  }
}

define load-env-file(path: &string, initial-buffer-size: int) -> system(unit) {
  try file = open(path, Read)[create := none];
  try content = read(file, initial-buffer-size);
  try _ = close(file);
  let _ = _read-env(content);
  Right(Unit)
}

define _from-system-to-option<a>(x: system(a)) -> ?a {
  match x {
  | Left(_) =>
    Left(Unit)
  | Right(v) =>
    Right(v)
  }
}

define _dtype-is-reg(d: &dtype) -> bool {
  case d {
  | DT_REG =>
    True
  | _ =>
    False
  }
}

define _find-env-dirent(xs: &list(dirent), env-file-name: &string) -> ?&dirent {
  case xs {
  | Nil =>
    none
  | Cons(dirent, rest) =>
    tie Dirent{kind, name} = dirent;
    let b1 = _dtype-is-reg(kind);
    let b2 = eq-string(name, env-file-name);
    if and::(b1, b2) {
      Right(dirent)
    } else {
      _find-env-dirent(rest, env-file-name)
    }
  | Cons(_, rest) =>
    _find-env-dirent(rest, env-file-name)
  }
}

define _find-env-file(cursor-directory: &string, env-file-name: &string) -> ?string {
  try items = _from-system-to-option(read-directory(cursor-directory));
  pin items = items;
  match _find-env-dirent(items, env-file-name) {
  | Right(dirent) =>
    tie Dirent{name} = dirent;
    let env-file-path = core::path.append(cursor-directory, name);
    Right(env-file-path)
  | Left(_) =>
    pin next-cursor = drop-last(cursor-directory);
    let should-finish = eq-string(next-cursor, cursor-directory);
    if should-finish {
      none
    } else {
      _find-env-file(next-cursor, env-file-name)
    }
  }
}

define find-env-file(env-file-name: &string) -> ?string {
  try cwd = _from-system-to-option(get-current-directory());
  pin cwd = cwd;
  _find-env-file(cwd, env-file-name)
}

define find-and-load-env-file(env-file-name: &string) -> ?unit {
  try env-file = find-env-file(env-file-name);
  pin env-file = env-file;
  _from-system-to-option(load-env-file(env-file, 1024))
}
